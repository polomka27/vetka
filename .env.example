# Скопируй этот файл в .env и заполни значения перед деплоем:
# cp .env.example .env

# Секретные ключи — сгенерируй случайные строки (например: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string

# PostgreSQL
POSTGRES_USER=vetka
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vetka

# CORS: список разрешённых origins через запятую (домен, с которого браузер делает запросы)
CORS_ORIGINS=https://yourdomain.com
