FLASK_APP=run.py
VETKA_CONFIG=production

SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string

POSTGRES_USER=vetka
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=vetka

# Список разрешённых origins через запятую. В docker-compose берётся из корневого .env.
CORS_ORIGINS=https://yourdomain.com

# Опционально: redis://redis:6379 для production rate-limiting (по умолчанию memory://)
RATELIMIT_STORAGE_URI=memory://
